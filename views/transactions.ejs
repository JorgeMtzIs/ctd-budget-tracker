<%- include("partials/head.ejs") %> <%- include("partials/header.ejs") %>
	<h2>Transactions List</h2>
	<h3>Expenses</h3>
	<table id="expense-table">
	<tr id="expense-table-header">
		<th>Amount</th>
		<th>Date</th>
		<th>Recurring</th>
		<th>Description</th>
	</tr>
	<% if (expenses && expenses.length) {%>
		<% expenses.forEach((expense) => {%>
			<tr>
				<td><%= expense.amount %></td>
				<td><%= expense.date %></td>
				<td><%= expense.recurring ? "Yes" : "No" %></td>
				<td><%= expense.description %></td>
				<td>
					<a href="/transactions/edit/<%= expense.id %>">
						<button type="button">edit</button>
					</a>
				</td>
				<td><form method="POST" action="/transactions/delete/<%= expense.id %>" style="display: inline">
						<button>delete</button>
					</form>
				</td>
			</tr>
			<% }) %>
		<% } %>
	</table>
	<h3>Income</h3>
	<table id="income-table">
	<tr id="income-table-header">
		<th>Amount</th>
		<th>Date</th>
		<th>Recurring</th>
		<th>Description</th>
	</tr>
	<% if (incomes && incomes.length) {%>
		<% incomes.forEach((income) => {%>
			<tr>
				<td><%= income.amount %></td>
				<td><%= income.date %></td>
				<td><%= income.recurring ? "Yes" : "No" %></td>
				<td><%= income.description %></td>
				<td>
					<a href="/transactions/edit/<%= income.id %>">
						<button type="button">edit</button>
					</a>
				</td>
				<td><form method="POST" action="/transactions/delete/<%= income.id %>" style="display: inline">
						<button>delete</button>
					</form>
				</td>
			</tr>
			<% }) %>
		<% } %>
	</table>
	<a href="/transactions/new">
			<button type="button">add transaction</button>
	</a>
<%- include("partials/footer.ejs") %>
